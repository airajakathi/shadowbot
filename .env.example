# ── ShadowBot Configuration ─────────────────────────────────────────────────

# StepFun (Primary LLM Provider - OpenAI Compatible)
OPENAI_API_KEY=your_stepfun_api_key_here
OPENAI_API_BASE=https://api.stepfun.ai/step_plan/v1
OPENAI_BASE_URL=https://api.stepfun.ai/step_plan/v1

# StepFun Models
SHADOWBOT_MODEL_FAST=step-3.5-flash
SHADOWBOT_MODEL_MAIN=step-3.6
SHADOWBOT_MODEL_IMAGE=step-image-edit-2
OPENAI_MODEL_NAME=step-3.6

STEPFUN_API_KEY=your_stepfun_api_key_here
STEPFUN_API_BASE=https://api.stepfun.ai/step_plan/v1

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Auto Model Routing
SHADOWBOT_AUTO_ROUTING=true

# Telemetry (permanently disabled)
PRAISONAI_TELEMETRY_DISABLED=true
DO_NOT_TRACK=true
